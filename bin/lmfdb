#!/usr/bin/env python3
"""
LMFDB CLI - Command-line tool for querying LMFDB
"""
import sys
import os

# Add the package to path
cli_dir = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, os.path.join(cli_dir, '..', 'share', 'lmfdb-cli'))

# Import and run the main CLI
try:
    from lmfdb_cli.main import app
    app()
except ImportError:
    print("Error: lmfdb-cli package not found.", file=sys.stderr)
    print("Please ensure dependencies are installed:", file=sys.stderr)
    print("  pip install lmfdb-cli", file=sys.stderr)
    sys.exit(1)
